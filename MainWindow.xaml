<Window x:Class="LengJiaoConnect.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="棱角互联" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#181818" Foreground="White"
        FontFamily="Microsoft YaHei">

    <Window.Resources>
        <Style TargetType="Button" x:Key="BigButtonStyle">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="HeaderButtonStyle">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="IconButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Name="MainContentLayer">
            <Grid.Effect>
                <BlurEffect Radius="0" x:Name="MainBlur" RenderingBias="Performance"/>
            </Grid.Effect>
            <Grid.RowDefinitions>
                <RowDefinition Height="90"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/> 
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="30,20,30,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="棱角互联" FontSize="26" FontWeight="Bold" Foreground="#E0E0E0"/>
                    <TextBlock Text="LengJiao Connect" FontSize="12" Foreground="#888888" Margin="10,8,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>

                <Border Name="StatusBarContainer" HorizontalAlignment="Center" VerticalAlignment="Center" Height="30" ClipToBounds="True" Opacity="0">
                    <Grid MinWidth="150">
                        <Grid>
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="TransFrame1" Y="0"/>
                            </Grid.RenderTransform>
                            <TextBlock Text="自动连接成功" Foreground="#4CAF50" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Grid>
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="TransFrame2" Y="30"/>
                            </Grid.RenderTransform>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="M2,22 L22,22 L22,2 Z" Fill="#AAAAAA" Height="14" Width="14" Stretch="Uniform" Margin="0,0,10,0" ToolTip="信号"/>
                                <Path Name="IconStatusWifi" Data="M12.01,21.49 L23.64,7 C23.19,6.66 18.71,3 12,3 C5.28,3 0.81,6.66 0.36,7 L11.99,21.49 C11.99,21.49 12.01,21.51 12.01,21.49 Z" Fill="#AAAAAA" Height="14" Width="16" Stretch="Uniform" Margin="0,0,10,0" Visibility="Collapsed" ToolTip="WiFi"/>
                                <Path Name="IconStatusBT" Data="M17.71,7.71 L12,2 L12,9.58 L6.41,4 L5,5.41 L10.59,11 L5,16.59 L6.41,18 L12,12.41 L12,20 L17.71,14.29 L13.41,11 L17.71,7.71 Z M14,5.83 L15.88,7.71 L14,9.58 L14,5.83 Z M15.88,14.29 L14,16.17 L14,12.42 L15.88,14.29 Z" Fill="#AAAAAA" Height="14" Width="12" Stretch="Uniform" Margin="0,0,10,0" Visibility="Collapsed" ToolTip="蓝牙"/>
                                <Path Data="M15.67,4 L14,4 L14,2 L10,2 L10,4 L8.33,4 C7.6,4 7,4.6 7,5.33 L7,20.67 C7,21.4 7.6,22 8.33,22 L15.67,22 C16.4,22 17,21.4 17,20.67 L17,5.33 C17,4.6 16.4,4 15.67,4 Z" Fill="#AAAAAA" Height="14" Width="10" Stretch="Uniform" Margin="0,0,4,0"/>
                                <TextBlock Name="TxtStatusBattery" Text="--%" Foreground="#AAAAAA" FontSize="13" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" Click="BtnDeviceMenu_Click" Style="{StaticResource HeaderButtonStyle}" Padding="15,8" Background="#252526" BorderThickness="1" BorderBrush="#333333">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Name="StatusDot" Width="10" Height="10" Fill="#555555" Margin="0,0,10,0"/>
                        <Path Name="IconConnectionType" Fill="#AAAAAA" Height="14" Stretch="Uniform" Margin="0,0,6,0" Visibility="Collapsed"/>
                        <TextBlock Name="TxtHeaderDeviceName" Text="未连接设备" FontSize="16" FontWeight="Bold" Foreground="#AAAAAA" Margin="0,0,10,0"/>
                        <TextBlock Text="▼" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="30,10,30,20">
                
                <Grid Name="PanelHomeButtons" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid Grid.Column="0">
                        <Button Content="投屏" Style="{StaticResource BigButtonStyle}" Name="BtnScreenCast" Click="BtnScreenCast_Click" Margin="20,20,20,60"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,25">
                            <Button Name="BtnToggleScreenMode" Content="💡 保持亮屏" Style="{StaticResource HeaderButtonStyle}" Background="#1A1A1A" Foreground="#AAAAAA" BorderThickness="1" BorderBrush="#333333" FontSize="12" Margin="0,0,10,0" Click="BtnToggleScreenMode_Click"/>
                            <Button Content="⚙️ 设置" Style="{StaticResource HeaderButtonStyle}" Background="#1A1A1A" Foreground="#AAAAAA" BorderThickness="1" BorderBrush="#333333" FontSize="12" Click="BtnScrcpySettings_Click"/>
                        </StackPanel>
                    </Grid>
                    
                    <Grid Grid.Column="1">
                        <Button Content="文件传输" Style="{StaticResource BigButtonStyle}" Name="BtnFileTransfer" Click="BtnFileTransfer_Click" Margin="20,20,20,60"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,25">
                            <Button Content="⚙️ 传输设置" Style="{StaticResource HeaderButtonStyle}" Background="#1A1A1A" Foreground="#AAAAAA" BorderThickness="1" BorderBrush="#333333" FontSize="12" Click="BtnTransferSettings_Click"/>
                        </StackPanel>
                    </Grid>
                    </Grid>

                <Grid Name="PanelFileManager" Visibility="Collapsed" Background="#1E1E1E" Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="TransFileManager" Y="30"/>
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Background="#252526">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                            <Button Content="← 返回" Style="{StaticResource HeaderButtonStyle}" Background="#333333" Margin="0,0,10,0" Click="BtnExitFileManager_Click"/>
                            <Button Content="↑ 上级" Style="{StaticResource HeaderButtonStyle}" Background="#333333" Margin="0,0,15,0" Click="BtnDirUp_Click"/>
                            
                            <TextBox Name="TxtCurrentPath" Text="/sdcard/" Width="350" Height="28" Background="#181818" Foreground="#AAAAAA" BorderThickness="1" BorderBrush="#333333" Padding="8,4" VerticalContentAlignment="Center" KeyDown="TxtCurrentPath_KeyDown"/>
                            <Button Content="刷新" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" Foreground="#007ACC" Margin="10,0,0,0" Click="BtnRefreshDir_Click"/>
                            
                            <Button Content="+ 新建文件夹/文件" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" Foreground="#4CAF50" Margin="20,0,0,0" Click="BtnShowNewItemPopup_Click"/>
                        </StackPanel>
                    </Grid>

                    <ListView Grid.Row="1" Name="ListFiles" AllowDrop="True" Drop="ListFiles_Drop" Background="Transparent" BorderThickness="0" Foreground="White" Margin="10" MouseDoubleClick="ListFiles_MouseDoubleClick">
                        <ListView.ContextMenu>
                            <ContextMenu Background="#252526" Foreground="White" BorderBrush="#333333">
                                <MenuItem Header="⬇️ 下载到电脑桌面" Click="MenuDownload_Click" Padding="10,5"/>
                                <Separator Background="#333333"/>
                                <MenuItem Header="🗑️ 彻底删除" Foreground="#FF5555" Click="MenuDelete_Click" Padding="10,5"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="名称" Width="400">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Icon}" Margin="0,0,10,0" FontSize="16"/>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{Binding TextColor}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="大小" Width="100" DisplayMemberBinding="{Binding Size}" />
                                <GridViewColumn Header="修改日期" Width="150" DisplayMemberBinding="{Binding Date}" />
                            </GridView>
                        </ListView.View>
                        
                        
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Height" Value="35"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/> <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Name="ItemBorder" CornerRadius="4" Background="Transparent" Margin="2,1">
                                                <GridViewRowPresenter VerticalAlignment="Center" Margin="10,0"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#2D2D30"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#333333"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#4CAF50"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                    <Grid Name="LoadingOverlay" Visibility="Collapsed" Grid.RowSpan="2" Background="#CC151515" Panel.ZIndex="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="250" Height="4" Foreground="#4CAF50" Background="#333333" BorderThickness="0" Margin="0,0,0,15"/>
                            <TextBlock Name="TxtLoadingHint" Text="正在处理中，请勿断开连接..." FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        <Grid Grid.Row="2" Margin="30,0,30,20">
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom">
                    <Button Name="BtnRebootMenu" Content="重启设备 ▼" Style="{StaticResource HeaderButtonStyle}" Background="#333333" Click="BtnRebootMenu_Click"/>
                    <Popup Name="RebootMenuPopup" PlacementTarget="{Binding ElementName=BtnRebootMenu}" Placement="Top" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="-5">
                        <Border Background="#252526" BorderBrush="#333333" BorderThickness="1" CornerRadius="6" Padding="5">
                            <StackPanel>
                                <Button Content="正常重启" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" HorizontalContentAlignment="Left" Margin="0,0,0,2" Click="MenuRebootNormal_Click"/>
                                <Button Content="重启至 Fastboot" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" HorizontalContentAlignment="Left" Margin="0,0,0,2" Click="MenuRebootFastboot_Click"/>
                                <Button Content="重启至 Recovery" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" HorizontalContentAlignment="Left" Margin="0,0,0,2" Click="MenuRebootRecovery_Click"/>
                                <Button Content="重启至 9008 (EDL)" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" Foreground="#FF5555" HorizontalContentAlignment="Left" Click="MenuRebootEDL_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                    <Button Name="BtnDisconnect" Content="断开无线连接" Style="{StaticResource HeaderButtonStyle}" Background="#C0392B" Margin="0,0,15,0" Visibility="Collapsed" Click="BtnDisconnect_Click"/>
                    <Button Name="BtnAdvancedToggle" Content="✨ 高级互联(未开启)" Style="{StaticResource HeaderButtonStyle}" Background="#E74C3C" Foreground="White" Margin="0,0,15,0" Click="BtnAdvancedToggle_Click"/>
                    <Button Content=">_ ADB 终端" Style="{StaticResource HeaderButtonStyle}" Background="#333333" Click="BtnOpenTerminal_Click" ToolTip="拉起内置 ADB 终端"/>
                </StackPanel>
            </Grid>

        </Grid> <Grid Name="PopupOverlay" Visibility="Collapsed" Panel.ZIndex="50">
            <Border Background="#99000000" MouseLeftButtonDown="Overlay_MouseLeftButtonDown"/>
            
            <Border Name="PopupContainer" Background="#252526" Width="450" MinHeight="300" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="12"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="PopupTransform" Y="0"/>
                </Border.RenderTransform>

                <Grid Margin="30">
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Style="{StaticResource IconButtonStyle}" Width="28" Height="28"
                            FontSize="16" Click="BtnClosePopup_Click" Panel.ZIndex="10"/>

                    <Grid Name="PanelDeviceCenter" Visibility="Collapsed" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="控制中心" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                            
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                                <StackPanel Name="DeviceListContainer">
                                    </StackPanel>
                            </ScrollViewer>

                            <Button Content="+ 添加新设备" Style="{StaticResource HeaderButtonStyle}" Background="#1E1E1E" Foreground="#4CAF50" BorderThickness="1" BorderBrush="#2D2D30" Height="40" Click="BtnAddNewDeviceFromMenu_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid Name="PanelPrivacyPolicy" Visibility="Collapsed" Margin="0,15,0,0">
                        <!-- 步骤1: 隐私协议和安装提示 -->
                        <StackPanel Name="PrivacyStep1">
                            <TextBlock Text="🛡️ 隐私与授权声明" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" LineHeight="22" Margin="0,0,0,15">
                                为了实现【手机通知实时推送到电脑】和【剪贴板双向互通】，我们需要在手机端安装一个专属的微型辅助应用（LengJiaoHelper）。
                                <LineBreak/><LineBreak/>
                                <Bold Foreground="White">软件会做什么：</Bold><LineBreak/>
                                1. 本地拦截系统的剪贴板变化，并仅通过内部局域网加密隧道发送至当前连接的电脑。<LineBreak/>
                                2. 本地读取应用通知内容，并仅发送至当前连接的电脑。
                                <LineBreak/><LineBreak/>
                                <Bold Foreground="White">软件不会做什么：</Bold><LineBreak/>
                                1. 绝对不会连接任何外部服务器，不会上传任何隐私数据到云端。<LineBreak/>
                                2. 没有任何广告，没有任何多余的后台唤醒行为，体积极小，省电无感。
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="拒绝" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Width="80" Margin="0,0,10,0" Click="BtnClosePopup_Click"/>
                                <Button Name="BtnPrivacyAgree" Content="同意并安装" Style="{StaticResource HeaderButtonStyle}" Background="#4CAF50" Foreground="White" BorderThickness="0" Width="120" Click="BtnPrivacyAgree_Click"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- 步骤2: 安装成功，提示前往设置授权 -->
                        <StackPanel Name="PrivacyStep2" Visibility="Collapsed">
                            <TextBlock Text="🎉 辅助服务安装成功" FontSize="20" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,15"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" LineHeight="22" Margin="0,0,0,20">
                                辅助服务已成功部署至您的手机（无桌面图标）。
                                <LineBreak/><LineBreak/>
                                要让高级互联生效，我们必须在手机系统中为其授予<Bold Foreground="White">【读取应用通知】</Bold>的权限。
                                <LineBreak/><LineBreak/>
                                稍后将自动为您打开手机的权限设置页面，请找到<Bold Foreground="#4CAF50">【棱角互联助手】</Bold>并开启开关！
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="稍后手动开启" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Width="120" Margin="0,0,10,0" Click="BtnClosePopup_Click"/>
                                <Button Content="前往手机授权" Style="{StaticResource HeaderButtonStyle}" Background="#4CAF50" Foreground="White" BorderThickness="0" Width="130" Click="BtnPrivacyGoToSettings_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 步骤3: 等待授权中 -->
                        <StackPanel Name="PrivacyStep3" Visibility="Collapsed" VerticalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#4CAF50" Background="#333333" BorderThickness="0" Margin="0,0,0,20"/>
                            <TextBlock Text="正在等待您在手机端完成授权..." FontSize="16" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="请在弹出的手机界面中，开启【棱角互联助手】的开关" FontSize="14" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                            <Button Content="取消等待" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" HorizontalAlignment="Center" Margin="0,20,0,0" Click="BtnClosePopup_Click"/>
                        </StackPanel>

                        <!-- 步骤4: 成功开启 -->
                        <StackPanel Name="PrivacyStep4" Visibility="Collapsed" VerticalAlignment="Center">
                            <TextBlock Text="✨ 高级互联已成功开启！" FontSize="24" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="现在，您的剪贴板和系统通知已经与电脑无缝打通！" FontSize="14" Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                            <Button Content="完成" Style="{StaticResource HeaderButtonStyle}" Background="#4CAF50" Foreground="White" BorderThickness="0" Width="120" HorizontalAlignment="Center" Click="BtnClosePopup_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid Name="PanelAdvancedSettings" Visibility="Collapsed" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="✨ 高级互联设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" Margin="0,0,0,20" LineHeight="20">
                                💡 <Bold>提示：</Bold>如果遇到通知风暴，请将发起连环通知的应用在手机上设为“静音通知”。受安卓系统安全限制，目前手机剪贴板无法自动读取并同步到电脑，但电脑的剪贴板依然可以单向推送给手机使用。
                            </TextBlock>
                            
                            <!-- 选项开关 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox Name="ChkSyncClipboard" Content="启用电脑到手机的单向剪贴板同步" IsChecked="True" Foreground="White" FontSize="14" Checked="ChkAdvancedOption_Changed" Unchecked="ChkAdvancedOption_Changed"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <CheckBox Name="ChkSyncNotifications" Content="启用手机非静音通知推送到电脑" IsChecked="True" Foreground="White" FontSize="14" Checked="ChkAdvancedOption_Changed" Unchecked="ChkAdvancedOption_Changed"/>
                            </StackPanel>
                            
                            <Button Content="⚙️ 再次打开手机端权限设置" Style="{StaticResource HeaderButtonStyle}" Background="#1E1E1E" Foreground="#AAAAAA" BorderThickness="1" BorderBrush="#333333" Height="40" Margin="0,0,0,10" Click="BtnOpenPermissionSettings_Click"/>
                            <Button Content="🗑️ 撤销授权并卸载服务" Style="{StaticResource HeaderButtonStyle}" Background="#331111" Foreground="#FF5555" BorderThickness="1" BorderBrush="#552222" Height="40" Click="BtnShowRevokeAuth_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid Name="PanelRevokeAuth" Visibility="Collapsed" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="⚠️ 确定撤销高级互联授权？" FontSize="20" FontWeight="Bold" Foreground="#FF5555" Margin="0,0,0,15"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" LineHeight="22" Margin="0,0,0,20">
                                <Bold Foreground="White">撤销授权会导致以下后果：</Bold>
                                <LineBreak/>❌ 失去剪贴板无缝双向跨端互通能力
                                <LineBreak/>❌ 无法在电脑端接收手机实时通知
                                <LineBreak/><LineBreak/>
                                您的手机上的微型辅助应用（LengJiaoHelper）将被彻底卸载，所有后台驻留服务将立刻销毁，不留任何痕迹。
                                <LineBreak/>您确定要继续撤销吗？
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="再想想" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Width="80" Margin="0,0,10,0" Click="BtnCancelRevoke_Click"/>
                                <Button Content="坚决卸载" Style="{StaticResource HeaderButtonStyle}" Background="#331111" Foreground="#FF5555" BorderThickness="1" BorderBrush="#552222" Width="100" Click="BtnConfirmRevoke_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid Name="PanelScrcpySettings" Visibility="Collapsed" Margin="0,5,0,0">
                        <StackPanel>
                            <TextBlock Text="⚙️ 投屏核心引擎设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,25"/>

                            <TextBlock Text="画质与延迟平衡策略" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button Grid.Column="0" Name="BtnSetQ_Low" Style="{StaticResource HeaderButtonStyle}" Background="#1E1E1E" BorderThickness="1" BorderBrush="#333333" Height="55" Click="BtnQuality_Click">
                                    <StackPanel>
                                        <TextBlock Text="流畅优先" FontWeight="Bold" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                        <TextBlock Text="2M / 限宽800" FontSize="11" Foreground="#666666" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button Grid.Column="2" Name="BtnSetQ_Mid" Style="{StaticResource HeaderButtonStyle}" Background="#252526" BorderThickness="1" BorderBrush="#4CAF50" Height="55" Click="BtnQuality_Click">
                                    <StackPanel>
                                        <TextBlock Text="均衡模式" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                                        <TextBlock Text="8M / 1080p" FontSize="11" Foreground="#888888" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="4" Name="BtnSetQ_High" Style="{StaticResource HeaderButtonStyle}" Background="#1E1E1E" BorderThickness="1" BorderBrush="#333333" Height="55" Click="BtnQuality_Click">
                                    <StackPanel>
                                        <TextBlock Text="画质狂魔" FontWeight="Bold" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                        <TextBlock Text="24M / 不限原画" FontSize="11" Foreground="#666666" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            
                            
                            

                            <TextBlock Text="特性开关" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                            <Button Name="BtnToggleAudio" Content="🔊 开启音频同步 (需 Android 11+)" Style="{StaticResource HeaderButtonStyle}" Background="#333333" Foreground="White" BorderThickness="1" BorderBrush="#555555" Height="40" HorizontalContentAlignment="Left" Margin="0,0,0,10" Click="BtnToggleAudio_Click"/>
                            <Button Name="BtnToggleControl" Content="🖱️ 允许电脑控制手机 (键鼠操作)" Style="{StaticResource HeaderButtonStyle}" Background="#333333" Foreground="White" BorderThickness="1" BorderBrush="#555555" Height="40" HorizontalContentAlignment="Left" Margin="0,0,0,25" Click="BtnToggleControl_Click"/>

                            <Button Content="保存并应用" Style="{StaticResource HeaderButtonStyle}" Background="#007ACC" Foreground="White" Height="40" Click="BtnClosePopup_Click"/>
                        </StackPanel>
                    </Grid>
                    <Grid Name="PanelNewItem" Visibility="Collapsed" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="新建项目" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                            <TextBlock Text="请输入名称 (带后缀名如 .txt 视为文件，否则为文件夹)" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <TextBox Name="InputNewItemName" Height="35" Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#333333" Padding="10,8" Margin="0,0,0,25"/>
                            <Button Content="确认创建" Style="{StaticResource HeaderButtonStyle}" Background="#4CAF50" Foreground="White" Height="40" Click="BtnConfirmNewItem_Click"/>
                        </StackPanel>
                    </Grid>
                    <Grid Name="PanelTransferSettings" Visibility="Collapsed" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="⚙️ 文件传输高级设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,25"/>
                            <TextBlock Text="系统设置" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                            <Button Name="BtnToggleAutoStart" Content="🚀 开机自动运行并在后台待命" Style="{StaticResource HeaderButtonStyle}" Background="#333333" Foreground="White" BorderThickness="1" BorderBrush="#555555" Height="40" HorizontalContentAlignment="Left" Margin="0,0,0,25" Click="BtnToggleAutoStart_Click"/>

                            <TextBlock Text="核心访问权限" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                            <Button Name="BtnToggleRoot" Content="🔓 开启 Root 提权模式 (su -c)" Style="{StaticResource HeaderButtonStyle}" Background="#333333" Foreground="White" BorderThickness="1" BorderBrush="#555555" Height="40" HorizontalContentAlignment="Left" Margin="0,0,0,15" Click="BtnToggleRoot_Click"/>

                            <TextBlock Text="显示首选项" Foreground="#AAAAAA" Margin="0,10,0,10"/>
                            <Button Name="BtnToggleHiddenFiles" Content="🙈 隐藏以点号开头的文件 (默认)" Style="{StaticResource HeaderButtonStyle}" Background="#333333" Foreground="White" BorderThickness="1" BorderBrush="#555555" Height="40" HorizontalContentAlignment="Left" Margin="0,0,0,25" Click="BtnToggleHiddenFiles_Click"/>

                            <Button Content="保存并应用" Style="{StaticResource HeaderButtonStyle}" Background="#007ACC" Foreground="White" Height="40" Click="BtnClosePopup_Click"/>
                        </StackPanel>
                    </Grid>
                    
                </Grid>
            </Border>
        </Grid>

        <Grid Name="OobeLayer" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Name="OobeOverlay" Background="#B3000000" Opacity="0"/>
            
            <Border Name="OobeContainer" Width="640" Height="400" CornerRadius="12" Background="#252526" ClipToBounds="True"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="OobeTransform" Y="40"/>
                </Border.RenderTransform>

                <Grid>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Style="{StaticResource IconButtonStyle}" Width="32" Height="32" Margin="10"
                            FontSize="16" Click="BtnCloseOobe_Click" Panel.ZIndex="10"/>

                    <Grid Name="OobeStep1">
                        <Grid.RenderTransform><TranslateTransform x:Name="TransStep1" X="0"/></Grid.RenderTransform>
                        <StackPanel VerticalAlignment="Center" Margin="40,0">
                            <TextBlock Text="欢迎使用 棱角互联" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="未检测到设备，请选择配置方式" FontSize="14" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Background="#1E1E1E" BorderThickness="1" BorderBrush="#333333" Cursor="Hand" Click="BtnOobeSelectWired_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Padding="15,20">
                                                <StackPanel>
                                                    <Path Data="M15,4 L15,8 L23,8 L23,20 L15,20 L15,24 L9,24 L9,20 L1,20 L1,8 L9,8 L9,4 Z" Fill="#4CAF50" Height="28" Stretch="Uniform" Margin="0,0,0,15"/>
                                                    <TextBlock Text="有线连接 (推荐)" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="即插即用，适合首次配置" FontSize="12" Foreground="#888888" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Grid.Column="2" Background="#1E1E1E" BorderThickness="1" BorderBrush="#333333" Cursor="Hand" Click="BtnOobeSelectWireless_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Padding="15,20">
                                                <StackPanel>
                                                    <Path Data="M12,2 C17.5,2 22.5,4 26,7.5 L24,9.5 C21,6.5 16.5,5 12,5 C7.5,5 3,6.5 0,9.5 L2,7.5 C5.5,4 10.5,2 12,2 Z M12,8 C15.5,8 18.5,9.5 21,11.5 L19,13.5 C17,12 14.5,11 12,11 C9.5,11 7,12 5,13.5 L3,11.5 C5.5,9.5 8.5,8 12,8 Z M12,14 C13.5,14 15,14.5 16,15.5 L12,19.5 L8,15.5 C9,14.5 10.5,14 12,14 Z" Fill="#007ACC" Height="28" Stretch="Uniform" Margin="0,0,0,15"/>
                                                    <TextBlock Text="无线连接" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="需同一局域网并配对" FontSize="12" Foreground="#888888" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Grid Name="OobeStep2Wired" Visibility="Collapsed">
                        <Grid.RenderTransform><TranslateTransform x:Name="TransStep2Wired" X="640"/></Grid.RenderTransform>
                        <Button Content="←" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource IconButtonStyle}" Width="32" Height="32" Margin="10" FontSize="20" Click="BtnOobeBack_Click" Panel.ZIndex="10"/>

                        <StackPanel VerticalAlignment="Center" Margin="50,0">
                            <TextBlock Text="等待设备接入" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="请开启手机的「USB 调试」功能，并使用数据线连接至电脑" FontSize="14" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                            
                            <Grid Height="80" Margin="0,0,0,30">
                                <Border Width="40" Height="70" CornerRadius="4" BorderThickness="2" BorderBrush="#555555" HorizontalAlignment="Left" Margin="150,0,0,0">
                                    <Border Height="8" Background="#555555" VerticalAlignment="Top" Margin="10,5,10,0"/>
                                </Border>
                                <Path Data="M200,40 L330,40" Stroke="#007ACC" StrokeThickness="4" StrokeDashArray="4 2"/>
                                <Path Data="M330,30 L360,30 L360,50 L330,50 Z" Fill="#888888" HorizontalAlignment="Left"/>
                            </Grid>

                            <TextBlock Name="TxtWiredStatus" Text="系统后台正在自动轮询，请直接插入手机..." FontSize="16" Foreground="#E0E0E0" HorizontalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <Grid Name="OobeStep3WirelessPair" Visibility="Collapsed">
                        <Grid.RenderTransform><TranslateTransform x:Name="TransStep3Pair" X="640"/></Grid.RenderTransform>
                        <Button Content="←" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource IconButtonStyle}" Width="32" Height="32" Margin="10" FontSize="20" Click="BtnOobeBack_Click" Panel.ZIndex="10"/>

                        <StackPanel VerticalAlignment="Center" Margin="50,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="无线连接 - 新设备配对" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="如何配对？" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" Foreground="#007ACC" FontSize="14" Margin="10,0,0,0" VerticalAlignment="Bottom" Click="BtnShowTutorial_Click"/>
                            </StackPanel>
                            
                            <TextBlock Text="首次连接 Android 11+ 设备，需获取并输入配对码" FontSize="13" Foreground="#AAAAAA" Margin="0,0,0,20"/>
                            
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="手机 IP 地址" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                                    <TextBox Name="OobeInputPairIp" Height="35" Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#333333" Padding="10,8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="配对专属端口" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                                    <TextBox Name="OobeInputPairPort" Height="35" Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#333333" Padding="10,8"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="6 位配对码" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <TextBox Name="OobeInputPairCode" Height="35" Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#333333" Padding="10,8" Margin="0,0,0,25"/>
                            
                            <Grid>
                                <Button Content="已配对或已 Root？跳过配对 →" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" Foreground="#888888" HorizontalAlignment="Left" Click="BtnToggleWirelessMode_Click"/>
                                <Button Name="BtnPairAction" Content="开始配对" Style="{StaticResource HeaderButtonStyle}" Width="120" Background="#007ACC" HorizontalAlignment="Right" Click="BtnOobeActionPair_Click"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Grid Name="OobeStep4WirelessConnect" Visibility="Collapsed">
                        <Grid.RenderTransform><TranslateTransform x:Name="TransStep4Connect" X="640"/></Grid.RenderTransform>
                        <Button Content="←" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource IconButtonStyle}" Width="32" Height="32" Margin="10" FontSize="20" Click="BtnOobeBack_Click" Panel.ZIndex="10"/>

                        <StackPanel VerticalAlignment="Center" Margin="50,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="无线连接 - 发起连接" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Background="#1A1A1A" CornerRadius="6" Padding="12" Margin="0,0,0,20" BorderThickness="1" BorderBrush="#333333">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💡" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="配置 Root 模块固化 5555 端口 + 路由绑定 IP，即可实现开机无感秒连。" 
                                               Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="已配对设备或 Root 固化端口设备，可直接输入连接端口" FontSize="13" Foreground="#AAAAAA" Margin="0,0,0,20"/>
                            
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="手机 IP 地址" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                                    <TextBox Name="OobeInputConnectIp" Height="35" Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#333333" Padding="10,8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="常规连接端口" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                                    <TextBox Name="OobeInputConnectPort" Text="5555" Height="35" Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#333333" Padding="10,8"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Name="TxtConnectStatus" Text="等待发起连接..." Foreground="#888888" Margin="0,10,0,30" HorizontalAlignment="Center"/>
                            
                            <Grid>
                                <Button Content="← 返回重新配对" Style="{StaticResource HeaderButtonStyle}" Background="Transparent" Foreground="#888888" HorizontalAlignment="Left" Click="BtnToggleWirelessMode_Click"/>
                                <Button Name="BtnConnectAction" Content="立即连接" Style="{StaticResource HeaderButtonStyle}" Width="120" Background="#4CAF50" HorizontalAlignment="Right" Click="BtnOobeActionConnect_Click"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Grid Name="OobeTutorialPanel" Visibility="Collapsed">
                        <Grid.RenderTransform><TranslateTransform x:Name="TransTutorial" X="640"/></Grid.RenderTransform>
                        <Button Content="←" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource IconButtonStyle}" Width="32" Height="32" Margin="10" FontSize="20" Click="BtnCloseTutorial_Click" Panel.ZIndex="10"/>
                        
                        <ScrollViewer Margin="50,40,50,20" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="无线连接教程" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                                <TextBlock Text="方案一：免 Root (仅限 Android 11 及以上)" FontSize="16" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,5"/>
                                <TextBlock Text="1. 确保电脑和手机连接在同一个局域网。&#x0a;2. 手机进入「开发者选项」，开启「无线调试」。&#x0a;3. 点击「使用配对码配对设备」。&#x0a;4. 记下弹窗中的配对码、IP 和 配对专属端口。&#x0a;5. 在软件的【配对面板】中填入并完成配对。&#x0a;6. 配对成功后，软件会自动左滑转入【连接面板】，此时填入手机「无线调试」外层主界面的常规连接端口，点击连接即可。" Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,15" LineHeight="20"/>
                                <TextBlock Text="方案二：已 Root (推荐，一劳永逸)" FontSize="16" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,5"/>
                                <TextBlock Text="1. 使用终端软件 (su) 设定固定端口：&#x0a;   setprop service.adb.tcp.port 5555&#x0a;   stop adbd&#x0a;   start adbd&#x0a;2. 直接在软件中点击【跳过配对】，端口填 5555，输入 IP 即可秒连。" Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,15" LineHeight="20"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
            
    </Grid>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,15,10" Panel.ZIndex="100">
            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0" Click="BtnGithubLink_Click" ToolTip="访问 GitHub">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.47C9.34,21.57 9.5,21.25 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.48C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z" 
                                  Fill="#666666" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="error-10" Foreground="#666666" FontSize="12" VerticalAlignment="Center" TextDecorations="Underline"/>
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="一条橙鱼" Background="Transparent" Foreground="#666666" BorderThickness="0" FontSize="12" Cursor="Hand" Click="BtnAuthorLink_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>